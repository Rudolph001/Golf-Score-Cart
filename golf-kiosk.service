[Unit]
Description=Golf Scorecard Kiosk Browser
After=golf-scorecard.service graphical.target
Wants=golf-scorecard.service

[Service]
Type=simple
User=pi
Environment=DISPLAY=:0
Environment=XAUTHORITY=/home/pi/.Xauthority
ExecStartPre=/bin/sleep 10
ExecStart=/bin/bash /home/pi/Golf-Score-Cart/kiosk.sh
Restart=on-failure
RestartSec=5

[Install]
WantedBy=graphical.target
